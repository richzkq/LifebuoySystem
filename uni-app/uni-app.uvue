  width: 500px; height: 500px;
  background-color: #D6E6F2;
  top: -100px; left: -100px;
}
.bg-pink {
  width: 450px; height: 450px;
  background-color: #F7E2E2;
  bottom: -50px; right: -100px;
}

.main-content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  padding: 24px;
  height: 100vh;
  box-sizing: border-box;
}

.header-section {
  margin-top: 40px;
  margin-bottom: 16px;
}
.brand-title {
  font-size: 26px;
  font-weight: 800;
  color: #2C3E50;
  letter-spacing: 2px;
}
.brand-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  margin-top: 4px;
  letter-spacing: 1px;
}

/* ── 设备选择器 ── */
.device-selector {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.68);
  border: 1px solid rgba(255,255,255,0.6);
  border-radius: 16px;
  padding: 12px 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 12px rgba(142,154,175,0.08);
}
.selector-label {
  font-size: 14px;
  font-weight: 600;
  color: #34495E;
}
.picker-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F0F4FF;
  border-radius: 10px;
  padding: 8px 14px;
  gap: 8px;
}
.picker-text {
  font-size: 14px;
  font-weight: 700;
  color: #2C3E50;
}
.picker-arrow {
  font-size: 10px;
  color: #7F8C8D;
}

/* ── 卡片 ── */
.glass-card {
  background-color: rgba(255, 255, 255, 0.68);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 28px;
  padding: 20px;
  box-shadow: 0 16px 40px rgba(142, 154, 175, 0.12);
  display: flex;
  flex-direction: column;
}

.status-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #E8F6EF;
  padding: 12px 16px;
  border-radius: 16px;
}
.status-bar-alert { background-color: #FFF0F0; }
.status-bar-safe  { background-color: #E3F2FD; }
.status-dot {
  width: 8px; height: 8px;
  background-color: #2ECC71;
  border-radius: 50%;
  margin-right: 12px;
}
.status-bar-alert .status-dot { background-color: #E74C3C; }
.status-bar-safe .status-dot  { background-color: #3498DB; }

@keyframes statusDotBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.status-dot-blink {
  animation: statusDotBlink 0.8s infinite;
}

.status-msg-text {
  font-size: 13px;
  font-weight: 600;
  color: #2C3E50;
  flex: 1;
}

.card-divider {
  height: 1px;
  background-color: rgba(0, 0, 0, 0.04);
  margin: 20px 0;
}

.modules-grid {
  display: flex;
