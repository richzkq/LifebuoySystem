<template>
  <view class="page-container">
    <view class="bg-glow bg-blue"></view>
    <view class="bg-glow bg-pink"></view>

    <view class="main-content" v-if="!showMonitor">
      <view class="header-section">
        <text class="brand-title">SMART LIFEBUOY</text>
        <text class="brand-subtitle">智能救生圈 · 中央数据看板</text>
      </view>

      <view class="device-selector">
        <text class="selector-label">监控设备</text>
        <picker :value="deviceIndex" :range="deviceList" @change="onDeviceChange">
          <view class="picker-box">
            <text class="picker-text">{{ deviceList[deviceIndex] }}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="glass-card">
        <view class="status-bar" :class="{
          'status-bar-alert': isAlarm == 1 && pressureStatus != 1,
          'status-bar-safe': pressureStatus == 1
        }">
          <view class="status-dot" :class="{'status-dot-blink': isAlarm == 1 && pressureStatus != 1}"></view>
          <text class="status-msg-text">{{ systemMessage }}</text>
        </view>

        <view class="card-divider"></view>

        <view class="modules-grid">
          <view class="module-item" :class="{'module-item-active-sound': callAlarmActive}">
            <view class="module-header">
              <text class="module-icon">🔊</text>
              <text class="module-title">呼救报警</text>
            </view>
            <view class="module-badge" :class="{'badge-active-sound': callAlarmActive}">
              <text class="badge-text" :class="{'badge-text-active': callAlarmActive}">
                {{ callAlarmActive ? '侦测到呼救' : '就绪中' }}
              </text>
            </view>
          </view>

          <view class="module-item" :class="{'module-item-active-vision': drowningCount > 0 && pressureStatus != 1}">
            <view class="module-header">
              <text class="module-icon">👁️</text>
              <text class="module-title">监控报警</text>
            </view>
            <view class="module-badge" :class="{'badge-active-vision': drowningCount > 0 && pressureStatus != 1}">
              <text class="badge-text" :class="{'badge-text-active': drowningCount > 0 && pressureStatus != 1}">
                {{ drowningCount > 0 && pressureStatus != 1 ? '溺水:' + drowningCount : '扫描中' }}
              </text>
            </view>
          </view>
        </view>

        <view class="voice-toggle">
          <view class="voice-row" @click="voiceEnabled = !voiceEnabled">
            <text class="voice-icon">{{ voiceEnabled ? '🔊' : '🔇' }}</text>
            <text class="voice-label">语音播报 {{ voiceEnabled ? '开' : '关' }}</text>
          </view>
        </view>

        <view class="card-divider"></view>

        <view class="device-info">
          <text class="info-line">📡 终端: {{ deviceId }}</text>
          <text class="info-line" v-if="temperature">🌡 温度: {{ temperature }}°C</text>
          <text class="info-line info-server">🔒 47.83.199.93</text>
        </view>
      </view>

      <view class="monitor-entry" @click="enterMonitor">
        <text class="entry-text">📷 查看实时监控画面</text>
        <text class="entry-arrow">▶</text>
      </view>
    </view>

    <view class="monitor-page" v-if="showMonitor">
      <view class="monitor-header">
        <view class="monitor-back" @click="showMonitor = false">
          <text class="back-arrow">◀</text>
          <text class="back-text">返回</text>
        </view>
        <text class="monitor-title">实时监控画面</text>
        <view class="monitor-spacer"></view>
      </view>

      <view class="device-selector">
        <text class="selector-label">当前设备</text>
        <picker :value="deviceIndex" :range="deviceList" @change="onDeviceChange">
          <view class="picker-box">
            <text class="picker-text">{{ deviceList[deviceIndex] }}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="monitor-video">
        <image class="monitor-image" :src="snapshotUrl" mode="aspectFit"></image>
        <view class="monitor-device-tag">📡 {{ deviceId }}</view>
      </view>

      <view class="monitor-footer">
        <text class="monitor-status" :class="{ 'monitor-alarm': isAlarm == 1 }">
          {{ isAlarm == 1 ? '⚠️ 报警中' : '🟢 正常监测' }}
        </text>
      </view>
    </view>
  </view>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue'

// ==================== 页面切换 ====================
const showMonitor = ref(false)

// ==================== 设备列表 ====================
const deviceList = ['rocket001']
const deviceIndex = ref(0)
const deviceId = computed(() => deviceList[deviceIndex.value])

// ==================== 状态 ====================
const currentFrame    = ref(0)
const drowningCount   = ref(0)
const heardCallCount  = ref(0)
const pressureStatus  = ref(0)
const isAlarm         = ref(0)
const temperature     = ref(null)
const systemMessage   = ref('初始化连接中...')
const callAlarmActive = ref(false)
const voiceEnabled    = ref(true)

const API_URL  = 'http://47.83.199.93:8080/device/latest'
const SNAP_URL = 'http://47.83.199.93:8080/device/snapshot'

const snapshotUrl = ref('')

let timer = null
let snapTimer = null
let callAlarmTimeout = null
let wasAlarm    = false
let wasCallHelp = false

const CALL_ALARM_HOLD_MS = 15000
const VOICE_COOLDOWN_MS  = 8000

let lastVoiceTime = 0

// ==================== 设备切换 ====================
const onDeviceChange = (e) => {
  deviceIndex.value = e.detail.value
  wasAlarm    = false
  wasCallHelp = false
  systemMessage.value = '已切换至 ' + deviceList[deviceIndex.value]
  fetchLiveStatus()
  refreshSnapshot()
}

// ==================== 进入监控 ====================
const enterMonitor = () => {
  showMonitor.value = true
  refreshSnapshot()
}

// ==================== 语音播报 ====================
const speak = (text) => {
  if (!voiceEnabled.value) return

  const now = Date.now()
  if (now - lastVoiceTime < VOICE_COOLDOWN_MS) return
  lastVoiceTime = now

  // #ifdef APP-PLUS
  if (typeof plus !== 'undefined' && plus.android) {
    try {
      const TTS    = plus.android.importClass('android.speech.tts.TextToSpeech')
      const Locale = plus.android.importClass('java.util.Locale')
      const main   = plus.android.runtimeMainActivity()

      const doSpeak = function() {
        try {
          const tts = plus.android.newObject(
            'android.speech.tts.TextToSpeech', main,
            plus.android.implements('android.speech.tts.TextToSpeech$OnInitListener', {
              onInit: function(status) {}
            })
          )
          plus.android.invoke(tts, 'setLanguage', Locale.CHINESE)
          plus.android.invoke(tts, 'setSpeechRate', 0.65)
          plus.android.invoke(tts, 'setPitch', 1.0)
          setTimeout(function() {
            try { plus.android.invoke(tts, 'speak', text, 0, null, null) } catch(e2) {}
          }, 2000)
        } catch(e) {}
      }
      doSpeak()
      return
    } catch(e) {}
  }
  // #endif

  // #ifdef H5
  if (typeof window !== 'undefined' && 'speechSynthesis' in window) {
    window.speechSynthesis.cancel()
    const utter = new SpeechSynthesisUtterance(text)
    utter.lang = 'zh-CN'
    utter.rate = 0.9
    utter.volume = 1.0
    window.speechSynthesis.speak(utter)
  }
  // #endif
}

const activateCallAlarm = () => {
  callAlarmActive.value = true
  if (callAlarmTimeout !== null) clearTimeout(callAlarmTimeout)
  callAlarmTimeout = setTimeout(() => {
    callAlarmActive.value = false
    callAlarmTimeout = null
    updateSystemMessage()
  }, CALL_ALARM_HOLD_MS)
}

const clearCallAlarm = () => {
  callAlarmActive.value = false
  if (callAlarmTimeout !== null) {
    clearTimeout(callAlarmTimeout)
    callAlarmTimeout = null
  }
}

const updateSystemMessage = () => {
  if (pressureStatus.value === 1) {
    systemMessage.value = 'SAFE: 救生圈压力传感器已触发，人员已抓靠，警报解除！'
  } else if (heardCallCount.value > 0) {
    systemMessage.value = '⚠️ WARNING: 侦测到呼救！请立即处理！'
  } else if (isAlarm.value === 1) {
    systemMessage.value = '⚠️ WARNING: 侦测到异常！溺水人数: ' + drowningCount.value
  } else {
    systemMessage.value = 'NORMAL: 监控中心待命中，当前水面安全。'
  }
}

const fetchLiveStatus = () => {
  uni.request({
    url: API_URL,
    method: 'GET',
    data: { deviceId: deviceId.value },
    success: (res) => {
      if (res.statusCode === 200 && res.data != null) {
        const data = res.data
        currentFrame.value   = parseInt(data['frameNo']       || 0)
        drowningCount.value  = parseInt(data['drowningCount'] || 0)
        heardCallCount.value = parseInt(data['callForHelp']   || 0)
        pressureStatus.value = parseInt(data['pressure']      || 0)
        isAlarm.value        = parseInt(data['alarm']         || 0)
        temperature.value    = data['temperature'] || null

        const visionNow = isAlarm.value === 1 && pressureStatus.value !== 1
        if (visionNow && !wasAlarm) {
          speak(deviceId.value + '，溺水报警！检测到疑似溺水者，请立即处理！')
        }
        if (pressureStatus.value === 1 && wasAlarm) {
          speak(deviceId.value + '，人员已获救，警报解除')
        }
        if (heardCallCount.value > 0 && !wasCallHelp) {
          speak(deviceId.value + '，侦测到呼救信号，请立即处理！')
        }

        wasAlarm    = visionNow
        wasCallHelp = heardCallCount.value > 0

        if (pressureStatus.value === 1) {
          clearCallAlarm()
        } else if (heardCallCount.value > 0) {
          activateCallAlarm()
        }
        updateSystemMessage()
      }
    },
    fail: (err) => {
      systemMessage.value = '❌ 服务器连接失败，请检查网络或后端服务'
    }
  })
}

function refreshSnapshot() {
  snapshotUrl.value = SNAP_URL + '/' + deviceId.value + '?t=' + Date.now()
}

onMounted(() => {
  fetchLiveStatus()
  timer = setInterval(fetchLiveStatus, 400)
})

onUnmounted(() => {
  if (timer) { clearInterval(timer); timer = null }
  if (snapTimer) { clearInterval(snapTimer); snapTimer = null }
  clearCallAlarm()
})
</script>

<style scoped>
