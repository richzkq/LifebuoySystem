  background-color: #FFF0F0; /* 报警樱花淡红 */
}
.status-bar-safe {
  background-color: #E3F2FD; /* 已获救安全马卡龙蓝 */
}
.status-dot {
  width: 8px;
  height: 8px;
  background-color: #2ECC71;
  border-radius: 50%;
  margin-right: 12px;
}
.status-bar-alert .status-dot {
  background-color: #E74C3C;
}
.status-bar-safe .status-dot {
  background-color: #3498DB;
}
.status-msg-text {
  font-size: 13px;
  font-weight: 600;
  color: #2C3E50;
  flex: 1;
}

.card-divider {
  height: 1px;
  background-color: rgba(0, 0, 0, 0.04);
  margin: 20px 0;
}

/* ── 模块双网格 ── */
.modules-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}
.module-item {
  width: 48%;
  background-color: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.8);
  border-radius: 20px;
  padding: 16px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
/* 声音激活：蜜桃红衬底 */
.module-item-active-sound {
  background-color: #FFF0F2;
  border: 1px solid #FFD3DA;
}
/* 视觉激活：香芋紫/熏衣蓝衬底 */
.module-item-active-vision {
  background-color: #F0F4FF;
  border: 1px solid #D2E0FF;
}
.module-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12px;
}
.module-icon {
  font-size: 20px;
  margin-right: 6px;
}
.module-title {
  font-size: 14px;
  font-weight: 700;
  color: #34495E;
}
.module-badge {
  background-color: #F0F3F5;
  padding: 4px 10px;
  border-radius: 10px;
}
.badge-active-sound { background-color: #FFD3DA; }
.badge-active-vision { background-color: #D2E0FF; }
.badge-text {
  font-size: 12px;
  color: #7F8C8D;
}
.badge-text-active {
  color: #D9534F;
  font-weight: bold;
}

/* ── 底部版权及信息 ── */
.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto; /* 修改：使底部自动贴紧窗口最下方 */
  padding-bottom: 20px;
}
.footer-device-id {
  font-size: 12px;
  color: #95A5A6;
  font-weight: 600;
}
.footer-secure-text {
  font-size: 11px;
  color: #BDC3C7;
  margin-top: 4px;
}
</style>