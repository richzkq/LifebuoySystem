  font-size: 14px;
  font-weight: 600;
  color: #34495E;
}
.picker-box {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F0F4FF;
  border-radius: 10px;
  padding: 8px 14px;
  gap: 8px;
}
.picker-text {
  font-size: 14px;
  font-weight: 700;
  color: #2C3E50;
}
.picker-arrow {
  font-size: 10px;
  color: #7F8C8D;
}

/* ── 卡片 ── */
.glass-card {
  background-color: rgba(255, 255, 255, 0.68);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 28px;
  padding: 20px;
  box-shadow: 0 16px 40px rgba(142, 154, 175, 0.12);
  display: flex;
  flex-direction: column;
}

.status-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #E8F6EF;
  padding: 12px 16px;
  border-radius: 16px;
}
.status-bar-alert { background-color: #FFF0F0; }
.status-bar-safe  { background-color: #E3F2FD; }
.status-dot {
  width: 8px; height: 8px;
  background-color: #2ECC71;
  border-radius: 50%;
  margin-right: 12px;
}
.status-bar-alert .status-dot { background-color: #E74C3C; }
.status-bar-safe .status-dot  { background-color: #3498DB; }

@keyframes statusDotBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.status-dot-blink {
  animation: statusDotBlink 0.8s infinite;
}

.status-msg-text {
  font-size: 13px;
  font-weight: 600;
  color: #2C3E50;
  flex: 1;
}

.card-divider {
  height: 1px;
  background-color: rgba(0,0,0,0.04);
  margin: 20px 0;
}

.modules-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}
.module-item {
  width: 48%;
  background-color: rgba(255,255,255,0.7);
  border: 1px solid rgba(255,255,255,0.8);
  border-radius: 20px;
  padding: 16px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.module-item-active-sound  { background-color: #FFF0F2; border: 1px solid #FFD3DA; }
.module-item-active-vision { background-color: #F0F4FF; border: 1px solid #D2E0FF; }
.module-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12px;
}
.module-icon  { font-size: 20px; margin-right: 6px; }
.module-title { font-size: 14px; font-weight: 700; color: #34495E; }
.module-badge { background-color: #F0F3F5; padding: 4px 10px; border-radius: 10px; }
.badge-active-sound  { background-color: #FFD3DA; }
.badge-active-vision { background-color: #D2E0FF; }
.badge-text         { font-size: 12px; color: #7F8C8D; }
.badge-text-active  { color: #D9534F; font-weight: bold; }

/* ── 语音开关 ── */
.voice-toggle {
  display: flex;
