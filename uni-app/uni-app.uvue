.header-section {
  margin-top: 40px;
  margin-bottom: 24px;
}
.brand-title {
  font-size: 26px;
  font-weight: 800;
  color: #2C3E50;
  letter-spacing: 2px;
}
.brand-subtitle {
  font-size: 13px;
  color: #7F8C8D;
  margin-top: 4px;
  letter-spacing: 1px;
}

/* ── 核心毛玻璃质感容器卡片（修改：自适应紧凑高度） ── */
.glass-card {
  background-color: rgba(255, 255, 255, 0.68);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-radius: 28px;
  padding: 20px;
  box-shadow: 0 16px 40px rgba(142, 154, 175, 0.12);
  display: flex;
  flex-direction: column;
}

/* ── 顶部业务状态横条 ── */
.status-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #E8F6EF; /* 默认薄荷浅绿 */
  padding: 12px 16px;
  border-radius: 16px;
}
