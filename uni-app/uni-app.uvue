  justify-content: space-between;
}
.module-item {
  width: 48%;
  background-color: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.8);
  border-radius: 20px;
  padding: 16px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.module-item-active-sound  { background-color: #FFF0F2; border: 1px solid #FFD3DA; }
.module-item-active-vision { background-color: #F0F4FF; border: 1px solid #D2E0FF; }
.module-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12px;
}
.module-icon  { font-size: 20px; margin-right: 6px; }
.module-title { font-size: 14px; font-weight: 700; color: #34495E; }
.module-badge { background-color: #F0F3F5; padding: 4px 10px; border-radius: 10px; }
.badge-active-sound  { background-color: #FFD3DA; }
.badge-active-vision { background-color: #D2E0FF; }
.badge-text         { font-size: 12px; color: #7F8C8D; }
.badge-text-active  { color: #D9534F; font-weight: bold; }

/* ── 语音开关 ── */
.voice-toggle {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 18px;
  padding: 10px;
  border-radius: 12px;
  background: rgba(0,0,0,0.03);
}
.voice-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
}
.voice-icon  { font-size: 16px; }
.voice-label { font-size: 13px; color: #7F8C8D; }
.voice-test-btn {
  background: #FF5E00;
  border-radius: 8px;
  padding: 6px 14px;
}
.test-btn-text {
  color: #fff;
  font-size: 12px;
  font-weight: 600;
}

/* ── 底部 ── */
.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: auto;
  padding-bottom: 20px;
}
.footer-device-id {
  font-size: 12px;
  color: #95A5A6;
  font-weight: 600;
}
.footer-secure-text {
  font-size: 11px;
  color: #BDC3C7;
  margin-top: 4px;
}
</style>
