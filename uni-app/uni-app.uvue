}
.info-line {
  font-size: 12px;
  color: #7F8C8D;
  font-weight: 500;
}
.info-server {
  color: #BDC3C7;
  font-size: 11px;
}

/* ── 进入监控按钮 ── */
.monitor-entry {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
  padding: 14px;
  border-radius: 16px;
  background: #FF5E00;
}
.entry-text {
  color: #fff;
  font-size: 15px;
  font-weight: 700;
}
.entry-arrow {
  color: #fff;
  font-size: 12px;
}

/* ==================== 副页面：实时监控（明亮玻璃拟态重构） ==================== */
.monitor-page {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  padding: 24px;
  height: 100vh;
  box-sizing: border-box;
  background: transparent;
}

.monitor-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 40px;
  margin-bottom: 16px;
}
