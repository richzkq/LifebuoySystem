  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.68);
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4px 12px rgba(142, 154, 175, 0.08);
}
.monitor-back:active {
  background: rgba(255, 255, 255, 0.9);
}
.back-arrow { 
  color: #2C3E50; 
  font-size: 11px; 
}
.back-text  { 
  color: #2C3E50; 
  font-size: 13px; 
  font-weight: 600; 
}
.monitor-title {
  color: #2C3E50;
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 1px;
}
.monitor-spacer { 
  width: 60px; 
}

.monitor-video {
  flex: 1;
  border-radius: 28px;
  overflow: hidden;
  background: #000; 
  position: relative;
  margin-bottom: 20px;
  box-shadow: 0 16px 40px rgba(142, 154, 175, 0.12);
  border: 4px solid rgba(255, 255, 255, 0.8); 
}
.monitor-image {
  width: 100%;
  height: 100%;
}
.monitor-device-tag {
  position: absolute;
  bottom: 16px;
  left: 16px;
  background: rgba(255, 255, 255, 0.75);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.6);
  color: #2C3E50;
  padding: 6px 14px;
  border-radius: 12px;
  font-size: 13px;
